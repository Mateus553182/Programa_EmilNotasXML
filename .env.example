# Configuracao de e-mail
# smtp (padrao) ou resend
EMAIL_PROVIDER=smtp

# SMTP (recomendado para uso imediato sem dominio proprio)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Emil NotasXML <seu-email@gmail.com>

# Opcional: fallback de desenvolvimento (nao entrega em caixa real)
# EMAIL_ALLOW_ETHEREAL=true

# Resend (usar quando tiver dominio verificado)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=sua_api_key_aqui
# RESEND_FROM_EMAIL=noreply@seudominio.com

# Mercado Pago (esboco da etapa de pagamento no cadastro)
# MERCADO_PAGO_ACCESS_TOKEN=seu_access_token
# MERCADO_PAGO_PREAPPROVAL_REDIRECT_URL=https://seu-link-preapproval
# MERCADO_PAGO_BRICKS_REDIRECT_URL=https://seu-link-bricks
